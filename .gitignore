*
!.gitignore
!package.json
!package-lock.json
!src/
!Cargo.toml

# docs — VitePress source only
!docs/
docs/*
!docs/index.md
!docs/.vitepress/
docs/.vitepress/*
!docs/.vitepress/config.js

# .github — workflow only
!.github/
.github/*
!.github/workflows/
.github/workflows/*
!.github/workflows/deploy-docs.yml
